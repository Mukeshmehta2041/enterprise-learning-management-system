{
  "family": "lms-elastic-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::448100672347:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "lms-elastic-service",
      "image": "elasticsearch:7.17.10",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 9200,
          "hostPort": 9200,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "discovery.type",
          "value": "single-node"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/lms-elastic-service",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}