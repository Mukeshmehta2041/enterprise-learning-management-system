{
  "family": "lms-kafka-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::448100672347:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "lms-kafka-service",
      "image": "redpandadata/redpanda:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 9092,
          "hostPort": 9092,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "REDPANDA_AUTO_CONFIG",
          "value": "true"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/lms-kafka-service",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}