{
  "family": "lms-payment-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::448100672347:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "lms-payment-service",
      "image": "lms-payment-service:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8089,
          "hostPort": 8089,
          "protocol": "tcp"
        }
      ],
      "environment": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/lms-payment-service",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}