{
  "family": "lms-postgres-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::448100672347:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "lms-postgres-service",
      "image": "postgres:15-alpine",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5432,
          "hostPort": 5432,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "POSTGRES_DB",
          "value": "lms"
        },
        {
          "name": "POSTGRES_USER",
          "value": "lms"
        },
        {
          "name": "POSTGRES_PASSWORD",
          "value": "lms_password"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/lms-postgres-service",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}